generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------
// 1. USUARIOS Y AUTH
// --------------------------------------------------------

model User {
  id        String    @id @default(uuid()) @db.VarChar(36)
  name      String
  email     String    @unique @db.VarChar(191)
  password  String
  image     String?   @db.Text
  role      String    @default("user")

  city      String?   // Nombre del pueblo/ciudad
  lat       Float?    // Latitud base del usuario
  lng       Float?    // Longitud base del usuario
  
  // --- RELACIONES DE VENTA Y COMPRA ---
  sales     Listing[] @relation("SellerRelation") // Lo que vende
  purchases Listing[] @relation("BuyerRelation")  // Lo que compra
  
  // --- FAVORITOS ---
  favorites Favorite[]

  // RELACIÓN CARRITO
  cart      Cart?

  // --- REVIEWS ---
  reviewsWritten  Review[]  @relation("ReviewAuthor")   // Las que escribe
  reviewsReceived Review[]  @relation("ReviewTarget")   // Las que recibe (su reputación)

  // --- Relación con los chats ---
  chatsAsBuyer  Chat[] @relation("ChatBuyer")
  chatsAsSeller Chat[] @relation("ChatSeller")
  messages      Message[]

  // --- TICKETS / REPORTES ---
  reports       Report[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// --------------------------------------------------------
// 2. CATÁLOGO BASE (Marcas, Consolas, Juegos)
// --------------------------------------------------------

model Brand {
  id       String    @id @default(uuid()) @db.VarChar(36)
  name     String    @unique @db.VarChar(191)
  country  String?
  logo     String?
  
  consoles Console[]
}

model Console {
  id          String    @id @default(uuid()) @db.VarChar(36)
  name        String
  shortName   String?
  releaseYear Int?
  image       String?   @db.Text
  
  brandId     String    @db.VarChar(36)
  brand       Brand     @relation(fields: [brandId], references: [id])
  
  games       Game[]    @relation("GamePlatforms") 
  listings    Listing[]
}

model Game {
  id          String    @id @default(uuid()) @db.VarChar(36)
  title       String
  coverImage  String?   @db.Text
  description String?   @db.Text
  genre       String    @default("Varios")
  releaseYear Int?
  
  platforms   Console[] @relation("GamePlatforms") 
  listings    Listing[]
}

// --------------------------------------------------------
// 3. MERCADO (Anuncios y Transacciones)
// --------------------------------------------------------

model Listing {
  id          String    @id @default(uuid()) @db.VarChar(36)
  price       Float
  condition   String
  description String?   @db.Text
  status      String    @default("active") // 'active', 'sold'
  
  // Ubicación del anuncio
  lat         Float?
  lng         Float?

  // --- VENDEDOR (Seller) ---
  sellerId    String    @db.VarChar(36)
  seller      User      @relation("SellerRelation", fields: [sellerId], references: [id])
  
  // --- COMPRADOR (Buyer) - Nuevo Campo ---
  buyerId     String?   @db.VarChar(36)
  buyer       User?     @relation("BuyerRelation", fields: [buyerId], references: [id])

  soldAt      DateTime? // Se rellenará solo cuando status pase a 'sold'

  // Relaciones del Producto
  gameId      String    @db.VarChar(36)
  game        Game      @relation(fields: [gameId], references: [id])
  
  platformId  String    @db.VarChar(36)
  platform    Console   @relation(fields: [platformId], references: [id])
  
  photos      ListingPhoto[]
  favoritedBy Favorite[]

  // RELACIÓN CARRITO (Para saber en qué carritos está este item)
  inCarts   CartItem[]

  // CAMPOS LOGÍSTICA
  shippingAddress String?  @db.Text             // Dirección completa de envío
  deliveryStatus  String   @default("pending")  // Estados: 'pending', 'shipped', 'delivered'

  // REVIEWS
  review      Review?

  // Relación inversa para el Chat
  chats       Chat[]

  // TICKETS / REPORTES
  reports     Report[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ListingPhoto {
  id        String  @id @default(uuid()) @db.VarChar(36)
  url       String
  listingId String  @db.VarChar(36)
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// --------------------------------------------------------
// 4. EXTRAS (Favoritos)
// --------------------------------------------------------

model Favorite {
  id        String   @id @default(uuid()) @db.VarChar(36)
  
  userId    String   @db.VarChar(36)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  listingId String   @db.VarChar(36)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, listingId]) 
}

// --------------------------------------------------------
// 5. CARRITO DE LA COMPRA
// --------------------------------------------------------

model Cart {
  id        String     @id @default(uuid()) @db.VarChar(36)
  
  userId    String     @unique @db.VarChar(36)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  items     CartItem[]

  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String   @id @default(uuid()) @db.VarChar(36)
  
  cartId    String   @db.VarChar(36)
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  
  listingId String   @db.VarChar(36)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  addedAt   DateTime @default(now())

  selected  Boolean  @default(true)

  // Un mismo producto solo puede estar una vez en un mismo carrito
  @@unique([cartId, listingId])
}

// --------------------------------------------------------
// 6. SOCIAL (Valoraciones)
// --------------------------------------------------------

model Review {
  id        String   @id @default(uuid()) @db.VarChar(36)
  
  rating    Int      // 1 a 5 estrellas
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  // Relaciones
  buyerId   String   @db.VarChar(36)
  buyer     User     @relation("ReviewAuthor", fields: [buyerId], references: [id])

  sellerId  String   @db.VarChar(36)
  seller    User     @relation("ReviewTarget", fields: [sellerId], references: [id])

  listingId String   @unique @db.VarChar(36) // Una review por venta
  listing   Listing  @relation(fields: [listingId], references: [id])
}

// --------------------------------------------------------
// 7. SISTEMA DE CHAT 
// --------------------------------------------------------

model Chat {
  id        String   @id @default(uuid()) @db.VarChar(36)
  
  buyerId   String   @db.VarChar(36)
  buyer     User     @relation("ChatBuyer", fields: [buyerId], references: [id])

  sellerId  String   @db.VarChar(36)
  seller    User     @relation("ChatSeller", fields: [sellerId], references: [id])

  listingId String?  @db.VarChar(36) 
  listing   Listing? @relation(fields: [listingId], references: [id])

  reportId  String?  @db.VarChar(36)
  report    Report?  @relation(fields: [reportId], references: [id], onDelete: Cascade)

  messages  Message[]

  updatedAt DateTime @updatedAt 
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(uuid()) @db.VarChar(36)
  
  content   String   @db.Text
  image     String?  @db.Text 
  
  chatId    String   @db.VarChar(36)
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  senderId  String   @db.VarChar(36)
  sender    User     @relation(fields: [senderId], references: [id])

  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// --------------------------------------------------------
// 8. SOPORTE E INCIDENCIAS (Tickets)
// --------------------------------------------------------

model Report {
  id        String   @id @default(uuid()) @db.VarChar(36)
  
  userId    String   @db.VarChar(36)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  listingId String?  @db.VarChar(36)
  listing   Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  
  subject   String   
  message   String   @db.Text
  status    String   @default("pending") 
  
  // NUEVO: Un ticket puede tener chats asociados
  chats     Chat[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}