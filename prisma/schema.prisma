// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------
// 1. USUARIOS Y AUTH
// --------------------------------------------------------

model User {
  id        String    @id @default(uuid()) @db.VarChar(36)
  name      String
  email     String    @unique @db.VarChar(191)
  password  String
  image     String?   @db.Text
  role      String    @default("user")
  
  // Relaciones existentes
  listings      Listing[]    // Anuncios que vende este usuario
  
  // --- NOVEDADES DASHBOARD ---
  favorites     Favorite[]   // Productos que le gustan
  ordersBought  Order[]      @relation("BuyerOrders") // Pedidos que ha COMPRADO
  ordersSold    Order[]      @relation("SellerOrders") // Pedidos que ha VENDIDO
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// --------------------------------------------------------
// 2. CATÁLOGO BASE (Marcas, Consolas, Juegos)
// --------------------------------------------------------

model Brand {
  id        String    @id @default(uuid()) @db.VarChar(36)
  name      String    @unique @db.VarChar(191)
  country   String?
  logo      String?
  
  consoles  Console[]
}

model Console {
  id          String    @id @default(uuid()) @db.VarChar(36)
  name        String
  shortName   String?
  releaseYear Int?
  image       String?
  
  brandId     String    @db.VarChar(36)
  brand       Brand     @relation(fields: [brandId], references: [id])
  
  games       Game[]    @relation("GamePlatforms") // Relación N:M para filtros
  listings    Listing[]
}

model Game {
  id          String    @id @default(uuid()) @db.VarChar(36)
  title       String
  coverImage  String?
  description String?   @db.Text
  genre       String?
  releaseYear Int?
  
  platforms   Console[] @relation("GamePlatforms") // Relación N:M para filtros
  listings    Listing[]
}

// --------------------------------------------------------
// 3. MERCADO (Anuncios y Transacciones)
// --------------------------------------------------------

model Listing {
  id          String    @id @default(uuid()) @db.VarChar(36)
  price       Float
  condition   String
  description String?   @db.Text
  status      String    @default("active") // 'active', 'sold', 'reserved'
  
  // Ubicación plana
  lat         Float?
  lng         Float?

  // Relaciones del Producto
  sellerId    String    @db.VarChar(36)
  seller      User      @relation(fields: [sellerId], references: [id])
  
  gameId      String    @db.VarChar(36)
  game        Game      @relation(fields: [gameId], references: [id])
  
  platformId  String    @db.VarChar(36)
  platform    Console   @relation(fields: [platformId], references: [id])
  
  photos      ListingPhoto[]

  // --- NOVEDADES DASHBOARD ---
  favoritedBy Favorite[] // Usuarios que han dado like
  order       Order?     // Si se vende, tendrá un pedido asociado (Relación 1 a 1 opcional)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ListingPhoto {
  id        String  @id @default(uuid()) @db.VarChar(36)
  url       String
  listingId String  @db.VarChar(36)
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// --- TABLA NUEVA: FAVORITOS ---
model Favorite {
  id        String   @id @default(uuid()) @db.VarChar(36)
  
  userId    String   @db.VarChar(36)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  listingId String   @db.VarChar(36)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Un usuario no puede dar like dos veces al mismo anuncio
  @@unique([userId, listingId]) 
}

// --- TABLA NUEVA: PEDIDOS (Historial) ---
model Order {
  id        String   @id @default(uuid()) @db.VarChar(36)
  
  totalPrice Float    // Guardamos el precio al que se vendió (por si cambia luego)
  status     String   @default("completed") // 'pending', 'completed', 'cancelled'

  // Relaciones
  listingId String   @unique @db.VarChar(36) // Un anuncio solo se vende una vez
  listing   Listing  @relation(fields: [listingId], references: [id])

  buyerId   String   @db.VarChar(36)
  buyer     User     @relation("BuyerOrders", fields: [buyerId], references: [id])

  sellerId  String   @db.VarChar(36) // Redundante pero útil para consultas rápidas de "Mis Ventas"
  seller    User     @relation("SellerOrders", fields: [sellerId], references: [id])

  createdAt DateTime @default(now())
}